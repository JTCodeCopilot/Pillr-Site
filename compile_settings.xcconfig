// Pillr Build Optimization Settings

// Enable build performance optimizations
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = wholemodule
SWIFT_WHOLE_MODULE_OPTIMIZATION = YES

// Increase compiler resources
OTHER_SWIFT_FLAGS = -Xfrontend -warn-long-function-bodies=200 -Xfrontend -warn-long-expression-type-checking=150 -Xfrontend -enable-batch-mode

// Build concurrent file operations - set to number of CPU cores
SWIFT_BUILD_OPERATION_MAX_CONCURRENT = 12

// Reduce debugging info in debug builds
DEBUG_INFORMATION_FORMAT = dwarf

// Cache build products
SWIFT_USE_INTEGRATED_DRIVER = YES

// Disable Index-While-Building - major improvement for preview performance
COMPILER_INDEX_STORE_ENABLE = NO

// Enable module caching
SWIFT_ENABLE_MODULE_CACHING = YES

// Optimize for fast build times
SWIFT_ENFORCE_EXCLUSIVE_ACCESS = off

// Set dSYM file type to none for faster debug builds
SWIFT_OPTIMIZATION_LEVEL[config=Debug] = -Onone
DEBUG_INFORMATION_FORMAT[config=Debug] = dwarf

// Build settings for optimized previews

// Set this to YES to optimize preview rendering performance
SWIFT_ACTIVE_COMPILATION_CONDITIONS[config=Debug][sdk=*] = DEBUG PREVIEW_OPTIMIZED

// Reduce preview build time by disabling compiler optimizations during development
SWIFT_OPTIMIZATION_LEVEL[config=Debug][sdk=*] = -Onone

// Only include essential resources in preview builds
EXCLUDED_SOURCE_FILE_NAMES[config=Debug][sdk=*] = unused_*.* test_*.*

// Enable faster incremental builds - use singlefile for faster previews
SWIFT_COMPILATION_MODE[config=Debug][sdk=*] = singlefile

// Enable parallel builds
SWIFT_USE_PARALLEL_WHOLE_MODULE_OPTIMIZATION = YES
SWIFT_USE_PARALLEL_WMO = YES
SWIFT_USE_PARALLEL_SOURCEINFO = YES

// Disable swift concurrency migration warnings in preview
SWIFT_SUPPRESS_WARNINGS[config=Debug][sdk=*] = YES

// Xcode preview specific settings
OTHER_SWIFT_FLAGS[config=Debug][sdk=*] = -Xfrontend -enable-experimental-concise-pound-file -Xfrontend -disable-availability-checking -Xfrontend -playground

// Enable build cache
SWIFT_ENABLE_BUILD_CACHE = YES
